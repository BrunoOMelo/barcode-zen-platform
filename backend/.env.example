APP_NAME=Barcode Zen Platform API
APP_ENV=development
API_V1_PREFIX=/api/v1
DB_ECHO=false
DATABASE_URL=postgresql+psycopg://barcode_zen:barcode_zen@localhost:5432/barcode_zen
AUTH_REQUIRED=true
AUTH_JWT_SECRET=change-me-in-env
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=480
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
